stageOne="./darwin_arm64_1"
stageTwo="./darwin_arm64_2"

rm -rf "$stageOne" "$stageTwo"
touch "$stageOne"
touch "$stageTwo"

stageOneFiles=(
  "./src/header"
  "./src/sudo"
  "./src/utils"
  "./src/constants"
  "./src/brew"
)

for file in "${stageOneFiles[@]}"; do
  cat "$file" >> "$stageOne"
  echo ""     >> "$stageOne"
done

stageTwoFiles=(
  "./src/header"
  "./src/sudo"
  "./src/utils"
  "./src/constants"
  "./src/shell"
  "./src/oh_my_zsh"
  "./src/dotfiles"
  "./src/submodules"
  "./src/vim"
  "./src/defaults"
)

for file in "${stageTwoFiles[@]}"; do
  cat "$file" >> "$stageTwo"
  echo ""     >> "$stageTwo"
done
