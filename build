output="./darwin_arm64"

rm -rf "$output"
touch "$output"

files=(
  "./src/header"
  "./src/sudo"
  "./src/utils"
  "./src/constants"
  "./src/brew"
  "./src/shell"
  "./src/oh_my_zsh"
  "./src/dotfiles"
  "./src/submodules"
  "./src/vim"
  "./src/defaults"
)

for file in "${files[@]}"; do
  cat "$file" >> "$output"
  echo ""     >> "$output"
done
