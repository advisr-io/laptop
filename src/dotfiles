dotfiles=(
  "asdf"
  "tmux-tmate.conf"
  "tmate.conf"
  "tmux.conf"
  "vim"
  "vimrc"
  "zprezto"
  "zlogin"
  "zlogout"
  "zpreztorc"
  "zprofile"
  "zshenv"
  "zshrc"
  "zsh-themes"
)

for dotfile in "${dotfiles[@]}"; do
  target="$LAPTOP_PREFIX/dotfiles/$dotfile"
  link="$HOME/.$dotfile"

  if [ -e "$link" ]; then
    if [ "$(readlink "$link")" == "$target" ]; then
      continue
    fi

    mv "$link" "$link.bak"
  fi

  echo "Installing $dotfile"
  ln -sf "$LAPTOP_PREFIX/dotfiles/$dotfile" "$HOME/.$dotfile"
done
