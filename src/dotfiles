dotfiles=(
  "./dotfiles/tmux-tmate.conf"
  "./dotfiles/tmate.conf"
  "./dotfiles/tmux.conf"
  "./dotfiles/vim"
  "./dotfiles/vimrc"
  "./dotfiles/zprezto"
  "./dotfiles/zlogin"
  "./dotfiles/zlogout"
  "./dotfiles/zpreztorc"
  "./dotfiles/zprofile"
  "./dotfiles/zshenv"
  "./dotfiles/zshrc"
  "./dotfiles/zsh-themes"
)

# Assuming CWD is your current working directory
CWD=$(pwd)

for dotfile in "${dotfiles[@]}"; do
  if [ -e "$HOME/.$dotfile" ]; then
    mv "$HOME/.$dotfile" "$HOME/$dotfile.bak"
  fi
  echo "Installing $dotfile"
  ln -sf "$CWD/$dotfile" "$HOME/.$dotfile"
done
