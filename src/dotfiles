dotfiles=(
  "tmux-tmate.conf"
  "tmate.conf"
  "tmux.conf"
  "vim"
  "vimrc"
  "zprezto"
  "zlogin"
  "zlogout"
  "zpreztorc"
  "zprofile"
  "zshenv"
  "zshrc"
  "zsh-themes"
)

for dotfile in "${dotfiles[@]}"; do
  if [ -e "$HOME/.$dotfile" ]; then
    mv "$HOME/.$dotfile" "$HOME/.$dotfile.bak"
  fi
  echo "Installing $dotfile"
  ln -sf "$LAPTOP_PREFIX/dotfiles/$dotfile" "$HOME/.$dotfile"
done
